{
  "name": "@mqueue/azure-service-bus",
  "version": "1.0.2",
  "type": "module",
  "description": "MQueue adapter for Azure Service Bus",
  "author": "Dom Webber <dom.webber@hotmail.com>",
  "contributors": [
    "Dom Webber <dom.webber@hotmail.com>"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "queue",
    "adapter",
    "azure-service-bus"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domwebber/mqueue.git",
    "directory": "packages/azure-service-bus"
  },
  "scripts": {
    "test": "node --import tsx --test --test-reporter=spec tests/**/*.test.ts tests/*.test.ts"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "peerDependencies": {
    "@mqueue/queue": "workspace:*"
  },
  "devDependencies": {
    "@mqueue/queue": "workspace:*"
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.5"
  },
  "overrides": {
    "fast-xml-parser": "5.6.0"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.6.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
